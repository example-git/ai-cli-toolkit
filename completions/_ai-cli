#compdef ai-cli claude codex copilot gemini
# Zsh completion for ai-cli and wrapped/native tool aliases.
# Generated by ai_cli.completion_gen

autoload -U is-at-least

_ai_cli_is_wrapped_cmd() {
  local cmd="$1"
  local resolved
  resolved="$(whence -p "$cmd" 2>/dev/null)"
  [[ "$resolved" == "$HOME/.ai-cli/bin/$cmd" ]]
}

_ai_cli_fill_tool_data() {
  local tool="$1"
  native_flags=()
  native_subcommands=()
  file_flags=()
  dir_flags=()
  case "$tool" in
    claude)
      native_flags=(--add-dir --agent --agents --allow-dangerously-skip-permissions --allowedTools --append-system-prompt --betas --chrome --continue --dangerously-skip-permissions --debug --debug-file --disable-slash-commands --disallowedTools --effort --fallback-model --file --fork-session --from-pr --help --ide --include-partial-messages --input-format --json-schema --max-budget-usd --mcp-config --mcp-debug --model --no-chrome --no-session-persistence --output-format --permission-mode --plugin-dir --print --replay-user-messages --resume --session-id --setting-sources --settings --strict-mcp-config --system-prompt --tmux --tools --verbose --version --worktree -c -d -h -p -r -v -w)
      native_subcommands=(auth doctor mcp plugin setup-token)
      file_flags=(--debug-file --file --json-schema --mcp-config --settings)
      dir_flags=(--add-dir --plugin-dir)
      ;;
    codex)
      native_flags=(--add-dir --ask-for-approval --cd --config --dangerously-bypass-approvals-and-sandbox --disable --enable --full-auto --help --image --local-provider --model --no-alt-screen --oss --profile --sandbox --search --version -C -V -a -c -h -i -m -p -s)
      native_subcommands=(exec review login logout mcp mcp-server app-server completion sandbox debug apply resume fork cloud features help)
      file_flags=(--config --local-provider --profile)
      dir_flags=(--add-dir)
      ;;
    copilot)
      native_flags=(--acp --add-dir --add-github-mcp-tool --add-github-mcp-toolset --additional-mcp-config --agent --allow-all --allow-all-paths --allow-all-tools --allow-all-urls --allow-tool --allow-url --alt-screen --autopilot --available-tools --banner --bash-env --config-dir --continue --deny-tool --deny-url --disable-builtin-mcps --disable-mcp-server --disallow-temp-dir --enable-all-github-mcp-tools --excluded-tools --experimental --help --interactive --log-dir --log-level --max-autopilot-continues --model --no-alt-screen --no-ask-user --no-auto-update --no-bash-env --no-color --no-custom-instructions --no-experimental --plain-diff --prompt --resume --screen-reader --share --share-gist --silent --stream --version --yolo -h -i -p -s -v)
      native_subcommands=(init plugin update version commands config environment logging permissions)
      file_flags=(--additional-mcp-config)
      dir_flags=(--add-dir --config-dir --log-dir)
      ;;
    gemini)
      native_flags=(--accept-raw-output-risk --allowed-mcp-server-names --allowed-tools --approval-mode --debug --delete-session --experimental-acp --extensions --help --include-directories --list-extensions --list-sessions --model --output-format --prompt --prompt-interactive --raw-output --resume --sandbox --screen-reader --version --yolo -d -e -h -i -l -m -o -p -r -s -v -y)
      native_subcommands=()
      file_flags=()
      dir_flags=()
      ;;
    *) ;;
  esac
}

_ai_cli_tool_completion_impl() {
  local tool="$1"
  _ai_cli_fill_tool_data "$tool"

  local -a flags
  flags=(${native_flags[@]})
  if _ai_cli_is_wrapped_cmd "$tool"; then
    flags+=(--ai-cli-system-instructions-file --ai-cli-system-instructions-text --ai-cli-canary-rule --ai-cli-passthrough --ai-cli-debug-requests --ai-cli-developer-instructions-mode --ai-cli-no-startup-context)
  fi

  local prev="${words[CURRENT-1]}"
  if (( ${file_flags[(Ie)$prev]} )); then
    _files
    return
  fi
  if (( ${dir_flags[(Ie)$prev]} )); then
    _directories
    return
  fi

  if [[ "${words[CURRENT]}" == -* ]]; then
    _describe 'option' flags
    return
  fi

  local i subcommand=""
  for ((i=2; i<CURRENT; i++)); do
    if [[ "${words[i]}" != -* ]]; then
      subcommand="${words[i]}"
      break
    fi
  done

  if [[ -z "$subcommand" ]]; then
    _describe 'command' native_subcommands
    _directories
  fi
}

_ai_cli_main_completion() {
  local cur="${words[CURRENT]}"
  local cmd="${words[2]}"

  if (( CURRENT == 2 )); then
    local -a sc
    sc=(
      "claude:Launch Claude Code agent"
      "codex:Launch OpenAI Codex agent"
      "copilot:Launch GitHub Copilot CLI"
      "gemini:Launch Google Gemini CLI"
      "menu:Interactive tool manager (TUI)"
      "status:Show installed tools and versions"
      "system:Edit or view system instructions"
      "prompt-edit:Edit global or tool prompt file"
      "session:Browse agent conversation history"
      "traffic:Browse and search proxied API traffic"
      "update:Install or update wrapped tools"
      "completions:Generate shell completion scripts"
      "help:Show usage information"
    )
    _describe 'command' sc
    return
  fi

  case "$cmd" in
    claude|codex|copilot|gemini)
      _ai_cli_tool_completion_impl "$cmd"
      return ;;
    system)
      if (( CURRENT == 3 )); then
        local -a sa
        sa=(
          "prompt:Show captured system prompt for a model"
          "claude:Edit Claude instructions"
          "codex:Edit Codex instructions"
          "copilot:Edit Copilot instructions"
          "gemini:Edit Gemini instructions"
        )
        _describe 'subcommand' sa
      else
        local -a tn
        tn=(claude codex copilot gemini)
        _describe 'tool' tn
      fi
      return ;;
    prompt-edit)
      if (( CURRENT == 3 )); then
        local -a sa
        sa=(
          "global:Edit global prompt file"
          "tool:Edit tool-specific prompt file"
        )
        _describe 'scope' sa
      elif (( CURRENT == 4 )); then
        local -a tn
        tn=(claude codex copilot gemini)
        _describe 'tool' tn
      fi
      return ;;
    session)
      case "${words[CURRENT-1]}" in
        --agent)
          local -a a
          a=(
            "all:All tools"
            "claude:Claude sessions"
            "codex:Codex sessions"
            "copilot:Copilot sessions"
            "gemini:Gemini sessions"
          )
          _describe 'agent' a
          return ;;
        --tail)
          _message 'number'
          return ;;
      esac
      if [[ "$cur" == -* ]]; then
        local -a sf
        sf=(
          "--agent:Filter by tool name"
          "--all:Show all sessions"
          "--list:List sessions"
          "--grep:Search session content"
          "--tail:Show last N entries"
          "--tools:Show tool metadata"
          "--raw:Raw output format"
        )
        _describe 'flag' sf
      else
        _files
      fi
      return ;;
    traffic)
      case "${words[CURRENT-1]}" in
        --caller|-c)
          local -a tc
          tc=(
            "claude:Show Claude traffic"
            "copilot:Show Copilot traffic"
            "codex:Show Codex traffic"
            "gemini:Show Gemini traffic"
          )
          _describe 'caller' tc
          return ;;
        --sort)
          local -a so
          so=(
            "date:Sort by timestamp (newest first)"
            "address:Sort by host and path"
          )
          _describe 'sort order' so
          return ;;
        --db)
          _files
          return ;;
        --host|--search|-s|--limit|-n|--detail|-d)
          return ;;
      esac
      if [[ "$cur" == -* ]]; then
        local -a tf
        tf=(
          "--caller:Filter by caller tool"
          "--host:Filter by host substring"
          "--search:Search request/response bodies"
          "--api:Show only confirmed API calls"
          "--sort:Sort order (date or address)"
          "--limit:Maximum rows to show"
          "--db:Path to traffic database"
          "--plain:Plain text output (no curses)"
          "--detail:Show detail for a specific row ID"
        )
        _describe 'flag' tf
      fi
      return ;;
    update)
      if [[ "$cur" == -* ]]; then
        local -a uf
        uf=(
          "--all:Update all tools"
          "--dry-run:Show what would be done"
          "--list:List available tools"
          "--method:Installation method"
          "--list-methods:List install methods"
        )
        _describe 'flag' uf
      else
        local -a tn
        tn=(claude codex copilot gemini)
        _describe 'tool' tn
      fi
      return ;;
    completions)
      if (( CURRENT == 3 )); then
        local -a acts
        acts=("generate:Generate completion scripts")
        _describe 'action' acts
      elif [[ "$cur" == -* ]]; then
        local -a cf
        cf=("--shell:Shell type (bash, zsh, all)")
        _describe 'flag' cf
      fi
      return ;;
  esac
}

_ai_cli_command_completion() { _ai_cli_main_completion "$@"; }
_ai_cli_claude_completion() { _ai_cli_tool_completion_impl claude; }
_ai_cli_codex_completion() { _ai_cli_tool_completion_impl codex; }
_ai_cli_copilot_completion() { _ai_cli_tool_completion_impl copilot; }
_ai_cli_gemini_completion() { _ai_cli_tool_completion_impl gemini; }

compdef _ai_cli_command_completion ai-cli
compdef _ai_cli_claude_completion claude
compdef _ai_cli_codex_completion codex
compdef _ai_cli_copilot_completion copilot
compdef _ai_cli_gemini_completion gemini
